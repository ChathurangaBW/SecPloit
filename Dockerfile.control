FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/secploit
RUN useradd --create-home --uid 10001 secploit

COPY pyproject.toml README.md scanner.py ./
COPY app ./app
COPY runner ./runner

RUN pip install --no-cache-dir .
RUN mkdir -p /data && chown -R secploit:secploit /data /opt/secploit
USER secploit

EXPOSE 8000
CMD ["uvicorn", "app.api:app", "--host", "0.0.0.0", "--port", "8000"]
