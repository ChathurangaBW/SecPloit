OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Comma-separated exact hosts or wildcard suffixes.
TARGET_ALLOWLIST=localhost,127.0.0.1,*.lab.internal

# The process runner executes one binary per agent step. No shell is used.
COMMAND_ALLOWLIST=curl,nmap,dig,nslookup,whois,openssl,jq,grep,sed,awk,cat,head,tail,ls,find,pwd,mkdir,cp,mv,touch,printf,echo

DATABASE_PATH=data/agent.db
WORKSPACE_ROOT=data/workspaces
COMMAND_TIMEOUT_SECONDS=120
MAX_OUTPUT_CHARS=20000
DEFAULT_MAX_STEPS=12
MAX_MAX_STEPS=40
