OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_CRITIC_MODEL=
OPENAI_REASONING_MODE=standard
OPENAI_REASONING_EFFORT=high
OPENAI_OPERATOR_REASONING_EFFORT=high
OPENAI_CRITIC_REASONING_EFFORT=high
OPENAI_MAX_OUTPUT_TOKENS=24000
OPENAI_STORE_RESPONSES=false
SECPLOIT_PLANNING_AGENTS=4
SECPLOIT_DATABASE_PATH=/data/secploit.sqlite3
SECPLOIT_RUNNER_URL=http://runner:9000
SECPLOIT_RUNNER_TOKEN=change-this-runner-token
SECPLOIT_TARGET_ALLOWLIST=juice-shop,dvwa,localhost,127.0.0.1
SECPLOIT_MAX_STEPS=30
SECPLOIT_MAX_WALL_SECONDS=1800
SECPLOIT_MAX_COMMAND_SECONDS=180
SECPLOIT_MAX_OUTPUT_BYTES=120000
SECPLOIT_WORKSPACE_IMAGE=secploit-runner:latest
SECPLOIT_RANGE_NETWORK=secploit-range
SECPLOIT_WORKSPACE_MEMORY=2g
SECPLOIT_WORKSPACE_CPUS=2
SECPLOIT_WORKSPACE_PIDS=512
SECPLOIT_CHROMIUM_PATH=/usr/bin/chromium
